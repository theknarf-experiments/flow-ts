{
  "name": "@flow-ts/parsing",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build:grammar": "peggy src/grammar.peggy --format es -o src/__generated__/grammar.js --dts",
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist src/__generated__"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "peggy": "^4.2.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
