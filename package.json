{
  "name": "flow-ts",
  "version": "0.1.0",
  "private": true,
  "description": "TypeScript port of FlowLog (a Datalog engine) on top of a vendored Tanstack db-ivm",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "mprocs",
    "build": "turbo run build",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules/.cache .turbo"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "mprocs": "^0.7.3",
    "turbo": "^2.3.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
