{
  "name": "@flow-ts/sync",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "spec:check": "quint typecheck spec/sync.qnt",
    "spec:run": "quint run --backend=typescript --invariants convergenceInv finishInvariantInv pulledEverythingInv --witnesses 'state.get(\"a\").roundComplete and state.get(\"b\").roundComplete' --max-steps=30 --max-samples=2000 spec/sync.qnt",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "cborg": "^4.2.0",
    "flow-ts": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "fast-check": "^4.8.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
