{
  "name": "@flow-ts/optimizing",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@flow-ts/catalog": "workspace:*",
    "@flow-ts/parsing": "workspace:*",
    "@flow-ts/strata": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "fast-check": "^4.8.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
